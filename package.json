{
  "name": "vue3-h5-starter",
  "type": "module",
  "version": "0.0.3",
  "description": "A Vue 3 mobile H5 starter template with Vite 8, Tailwind CSS v4, Vant 4, Pinia, TanStack Query, built-in examples, and AI-ready conventions.",
  "license": "MIT",
  "keywords": [
    "vue",
    "vue3",
    "vite",
    "h5",
    "mobile",
    "template",
    "starter",
    "typescript",
    "vant",
    "pinia",
    "tailwindcss"
  ],
  "engines": {
    "node": ">= 22.21.1"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:test": "vue-tsc --noEmit && vite build --mode test",
    "build:prod": "vue-tsc --noEmit && vite build --mode production",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "release": "standard-version",
    "commit": "czg",
    "prepare": "husky"
  },
  "dependencies": {
    "@tanstack/vue-query": "^5.92.9",
    "@vueuse/core": "^14.2.0",
    "axios": "^1.7.7",
    "clsx": "^2.1.1",
    "normalize.css": "^8.0.1",
    "nprogress": "^0.2.0",
    "pinia": "^2.2.5",
    "tailwind-merge": "^3.5.0",
    "vant": "^4.9.8",
    "vue": "^3.5.12",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.4.3",
    "@commitlint/config-conventional": "^19.5.0",
    "@iconify-icons/lucide": "^1.2.135",
    "@iconify/vue": "^4.1.2",
    "@tailwindcss/postcss": "^4.2.4",
    "@tanstack/vue-query-devtools": "^6.1.4",
    "@types/node": "^22.8.7",
    "@types/nprogress": "^0.2.3",
    "@vitejs/plugin-legacy": "^8.0.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.5.1",
    "cnjm-postcss-px-to-viewport": "^1.0.1",
    "code-inspector-plugin": "^0.19.2",
    "commitlint": "^19.5.0",
    "czg": "^1.12.0",
    "eslint": "^9.14.0",
    "eslint-plugin-format": "^1.4.0",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.6",
    "jiti": "^2.6.1",
    "less": "^4.2.0",
    "lint-staged": "^16.3.2",
    "postcss": "^8.4.47",
    "standard-version": "^9.5.0",
    "tailwindcss": "^4.2.4",
    "terser": "^5.46.0",
    "typescript": "~5.6.3",
    "unplugin-auto-import": "^0.18.5",
    "unplugin-vue-components": "^0.27.5",
    "unplugin-vue-router": "^0.19.2",
    "vconsole": "^3.15.1",
    "vite": "^8.0.16",
    "vite-plugin-cdn2": "^1.1.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-mock-dev-server": "^2.4.0",
    "vite-plugin-svg-icons": "^2.0.1",
    "vite-plugin-vconsole": "^2.1.1",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vitest": "^4.1.2",
    "vue-tsc": "^2.1.10"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue}": [
      "eslint --fix"
    ]
  }
}
